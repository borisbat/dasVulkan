options gen2
options indenting = 4

require daslib/rtti

// dastest folder filter for the tutorials tree. Each tutorial's pixel-oracle gate needs only
// vulkan + dasSpirv and always runs (lavapipe in CI, real GPU locally). The recording drivers
// (capture -> APNG -> ffmpeg mp4 + strudel bed) live in each tutorial's `recording/` subdir and
// require the stbimage + audio modules, which the lavapipe CI daslang build does not load -- so
// those folders are skipped in CI and active locally where the full daslang build is present.
[export, pinvoke]
def can_visit_folder(folder_name : string; var result : bool?) {
    if (folder_name == "recording") {
        *result = has_module("stbimage") && has_module("audio")
        return
    }
}
